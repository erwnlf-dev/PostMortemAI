# PostMortem AI Configuration Environment Variables

# The default model provider (openai, anthropic, custom)
VITE_DEFAULT_PROVIDER=openai

# Default model name
VITE_DEFAULT_MODEL=gpt-4o

# Optional custom OpenAI-compatible API base URL
VITE_CUSTOM_BASE_URL=

# Analytics integration (optional)
VITE_SENTRY_DSN=
